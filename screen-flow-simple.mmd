flowchart TD
    ENTRY(["/ アクセス"]):::entry

    ENTRY -->|"未ログイン"| PORTAL
    ENTRY -->|"admin"| ADMIN
    ENTRY -->|"operator"| OPS

    %% ── AUTH ──────────────────────────────────────
    PORTAL["Portal\n/portal\nGoogle / Manus ログイン"]:::page
    OAUTH(["外部OAuth\n認証"]):::ext

    PORTAL --> OAUTH
    OAUTH -->|"admin"| ADMIN
    OAUTH -->|"operator"| OPS
    OAUTH -->|"失敗"| PORTAL

    %% ── VISITOR ───────────────────────────────────
    subgraph VISITOR ["👤 訪問者チャット"]
        V_START["ChatStart\n/chat\n開始フォーム"]:::page
        V_ROOM["ChatRoom\n/chat/:id\nAI + オペレーター対応"]:::page
        V_SURVEY["アンケートモーダル"]:::modal
    end

    V_START -->|"送信"| V_ROOM
    V_ROOM -->|"終了"| V_SURVEY
    V_SURVEY -->|"完了"| V_START

    %% ── WIDGET ────────────────────────────────────
    subgraph WIDGET ["🔲 埋め込みウィジェット（iframe）"]
        W["WidgetChat\n/widget-chat\nstart → chat → ended"]:::page
    end

    EMBED(["外部サイト"]):::ext
    EMBED -->|"iframe"| W
    W -->|"閉じる / 完了"| EMBED

    %% ── OPERATOR ──────────────────────────────────
    subgraph OPS ["🎧 オペレーター"]
        OPS_LIST["チャット一覧\n/ops/chats"]:::page
        OPS_DETAIL["チャット対応\n/ops/chats/:id"]:::page
        OPS_QR["定型文\n/ops/quick-replies"]:::page
    end

    OPS_LIST <-->|"サイドバー"| OPS_QR
    OPS_LIST <-->|"選択 / 戻る"| OPS_DETAIL

    %% ── ADMIN ─────────────────────────────────────
    subgraph ADMIN ["🛠 管理者"]
        A_DASH["ダッシュボード\n/admin"]:::page
        A_CHATS["チャット一覧\n/admin/chats"]:::page
        A_REPLY["チャット対応\n/admin/chats/:id/reply"]:::page
        A_MGMT["管理ページ群\nOperators / Quick Replies\nRAG / Feedback / Data Analysis"]:::group
    end

    A_DASH <-->|"サイドバー"| A_CHATS
    A_DASH <-->|"サイドバー"| A_MGMT
    A_CHATS <-->|"選択 / 戻る"| A_REPLY

    %% ── AUTH GUARD / LOGOUT ───────────────────────
    OPS_LIST & ADMIN -->|"未認証 / ログアウト"| PORTAL

    %% ── STYLES ────────────────────────────────────
    classDef entry  fill:#000,color:#fff,stroke:#000
    classDef page   fill:#fff,color:#111,stroke:#555,stroke-width:1.5px
    classDef modal  fill:#eef2ff,color:#111,stroke:#818cf8,stroke-width:1.5px
    classDef ext    fill:#f5f5f5,color:#666,stroke:#bbb,stroke-dasharray:4 2
    classDef group  fill:#f9fafb,color:#374151,stroke:#9ca3af,stroke-width:1px
