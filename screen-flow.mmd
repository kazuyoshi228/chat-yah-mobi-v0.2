flowchart TD
    %% ─────────────────────────────────────────────
    %% ENTRY POINTS
    %% ─────────────────────────────────────────────
    ENTRY(["ブラウザアクセス /"]):::entry

    ENTRY --> ROOT["RootRedirect\n/"]:::page

    ROOT -->|"未ログイン"| PORTAL
    ROOT -->|"role=admin"| ADMIN_DASH
    ROOT -->|"role=operator"| OPS_CHATS

    %% ─────────────────────────────────────────────
    %% PORTAL / AUTH
    %% ─────────────────────────────────────────────
    PORTAL["Portal\n/portal\nログイン選択画面"]:::page

    PORTAL -->|"Log in with Google\n→ /api/auth/google"| GOOGLE_AUTH
    PORTAL -->|"Log in with Manus\n→ Manus OAuth"| MANUS_AUTH

    GOOGLE_AUTH(["Google OAuth\n外部認証"]):::external
    MANUS_AUTH(["Manus OAuth\n外部認証"]):::external

    GOOGLE_AUTH -->|"認証成功\nrole=admin"| ADMIN_DASH
    GOOGLE_AUTH -->|"認証成功\nrole=operator"| OPS_CHATS
    GOOGLE_AUTH -->|"認証失敗\n?error=..."| PORTAL

    MANUS_AUTH -->|"認証成功\nrole=admin"| ADMIN_DASH
    MANUS_AUTH -->|"認証成功\nrole=operator"| OPS_CHATS

    %% ─────────────────────────────────────────────
    %% VISITOR CHAT FLOW
    %% ─────────────────────────────────────────────
    subgraph VISITOR ["👤 訪問者チャット（直接アクセス）"]
        CHAT_START["ChatStart\n/chat\nチャット開始フォーム\n（名前・メール・メッセージ入力）"]:::page
        CHAT_ROOM["ChatRoom\n/chat/:sessionId\nリアルタイムチャット\n（AI自動応答）"]:::page
        SURVEY_MODAL["SurveyModal\n（モーダル）\n満足度アンケート\n（★評価・解決確認・自由記述）"]:::modal
    end

    CHAT_START -->|"チャット開始\nstartSession"| CHAT_ROOM
    CHAT_ROOM -->|"セッションID無効"| CHAT_START
    CHAT_ROOM -->|"End ボタン\nまたは\nsession_ended イベント"| SURVEY_MODAL
    SURVEY_MODAL -->|"送信 / 閉じる"| CHAT_START

    CHAT_ROOM -->|"エスカレーション要求\nrequestEscalation"| CHAT_ROOM
    CHAT_ROOM -->|"operator_joined イベント\n→ AI応答停止"| CHAT_ROOM

    %% ─────────────────────────────────────────────
    %% WIDGET FLOW
    %% ─────────────────────────────────────────────
    subgraph WIDGET ["🔲 埋め込みウィジェット（iframe）"]
        W_START["WidgetChat\n/widget-chat\nSTAGE: start\n開始フォーム"]:::page
        W_CHAT["WidgetChat\n/widget-chat\nSTAGE: chat\nリアルタイムチャット"]:::page
        W_ENDED["WidgetChat\n/widget-chat\nSTAGE: ended\nチャット終了"]:::page
        W_SURVEY["アンケートUI\n（インライン）"]:::modal
        W_AUTH_SUCCESS["WidgetAuthSuccess\n/widget-auth-success\n（別タブ）\nGoogle認証コールバック"]:::page
    end

    EMBED_SCRIPT(["外部サイト\n/widget.js 埋め込み"]):::external
    EMBED_SCRIPT -->|"iframe生成"| W_START

    W_START -->|"Googleでログイン\n→ /api/auth/google/widget\n（新タブ）"| W_AUTH_SUCCESS
    W_AUTH_SUCCESS -->|"localStorage保存\n→ タブ自動クローズ"| W_START
    W_START -->|"startSession 成功"| W_CHAT
    W_CHAT -->|"endSession\nまたは session_ended"| W_ENDED
    W_ENDED -->|"アンケート表示"| W_SURVEY
    W_SURVEY -->|"送信 / 閉じる\n→ yah:close 送信"| EMBED_SCRIPT
    W_CHAT -->|"X ボタン\n→ yah:close 送信"| EMBED_SCRIPT
    W_CHAT -->|"未読メッセージ\n→ yah:unread 送信"| EMBED_SCRIPT

    %% ─────────────────────────────────────────────
    %% OPERATOR PANEL
    %% ─────────────────────────────────────────────
    subgraph OPERATOR ["🎧 オペレーターパネル（要認証）"]
        OPS_CHATS["OperatorChats\n/ops/chats\nチャット一覧\n（waiting/active/ended フィルター）"]:::page
        OPS_DETAIL["OperatorChatDetail\n/ops/chats/:id\nチャット詳細・対応画面\n（メッセージ送信・画像添付）"]:::page
        OPS_QR["OperatorQuickReplies\n/ops/quick-replies\n定型文一覧（閲覧専用）"]:::page
    end

    OPS_CHATS -->|"セッションカードクリック"| OPS_DETAIL
    OPS_CHATS -->|"new_session / escalation_alert\nトースト通知クリック"| OPS_DETAIL
    OPS_CHATS -->|"サイドバー\nQuick Replies"| OPS_QR
    OPS_QR -->|"サイドバー\nChat List"| OPS_CHATS

    OPS_DETAIL -->|"← 戻るボタン"| OPS_CHATS
    OPS_DETAIL -->|"End Session 成功\n→ /ops/chats"| OPS_CHATS
    OPS_DETAIL -->|"サイドバー\nChat List"| OPS_CHATS
    OPS_DETAIL -->|"サイドバー\nQuick Replies"| OPS_QR

    OPS_DETAIL -->|"assignSession\n（自分にアサイン）"| OPS_DETAIL
    OPS_DETAIL -->|"generateSummary"| OPS_DETAIL

    %% ─────────────────────────────────────────────
    %% ADMIN PANEL
    %% ─────────────────────────────────────────────
    subgraph ADMIN ["🛠 管理者パネル（要admin権限）"]
        ADMIN_DASH["AdminDashboard\n/admin\nKPIダッシュボード\n（今日/今週/今月フィルター）"]:::page
        ADMIN_CHATS["AdminChatList\n/admin/chats\nチャット一覧\n（all/waiting/active/ended）"]:::page
        ADMIN_DETAIL["AdminChatDetail\n/admin/chats/:id\nチャット詳細（閲覧専用）\nForce End 可能"]:::page
        ADMIN_REPLY["AdminChatReply\n/admin/chats/:id/reply\nチャット対応画面\n（メッセージ送信・アサイン）"]:::page
        ADMIN_OPS["AdminOperators\n/admin/operators\nオペレーター管理\n（追加・ロール変更）"]:::page
        ADMIN_QR["AdminQuickReplies\n/admin/quick-replies\n定型文管理\n（追加・編集・削除）"]:::page
        ADMIN_RAG["AdminRag\n/admin/rag\nRAGドキュメント管理\n（追加・編集・削除・有効期限）"]:::page
        ADMIN_FEEDBACK["AdminFeedback\n/admin/feedback\nアンケート一覧\n（評価・コメント閲覧）"]:::page
        ADMIN_ANALYSIS["AdminDataAnalysis\n/admin/data-analysis\nデータ分析\n（グラフ・画像AI解析）"]:::page
    end

    ADMIN_DASH -->|"Waiting カード\n→ /admin/chats?status=waiting"| ADMIN_CHATS
    ADMIN_DASH -->|"Active カード\n→ /admin/chats?status=active"| ADMIN_CHATS
    ADMIN_DASH -->|"サイドバー Chat List"| ADMIN_CHATS
    ADMIN_DASH -->|"サイドバー Operators"| ADMIN_OPS
    ADMIN_DASH -->|"サイドバー Quick Replies"| ADMIN_QR
    ADMIN_DASH -->|"サイドバー RAG Documents"| ADMIN_RAG
    ADMIN_DASH -->|"サイドバー Feedback"| ADMIN_FEEDBACK
    ADMIN_DASH -->|"サイドバー Data Analysis"| ADMIN_ANALYSIS

    ADMIN_CHATS -->|"セッションカードクリック\n→ /admin/chats/:id/reply"| ADMIN_REPLY
    ADMIN_CHATS -->|"サイドバーで他ページへ"| ADMIN_DASH

    ADMIN_REPLY -->|"← 戻る\n→ /admin/chats"| ADMIN_CHATS
    ADMIN_REPLY -->|"End Chat 成功\n→ /admin/chats"| ADMIN_CHATS
    ADMIN_REPLY -->|"assignChat\n（自分にアサイン）"| ADMIN_REPLY
    ADMIN_REPLY -->|"refreshSummary"| ADMIN_REPLY

    ADMIN_DETAIL -->|"← 戻る\n→ /admin/chats"| ADMIN_CHATS
    ADMIN_DETAIL -->|"Force End\n（同ページ更新）"| ADMIN_DETAIL

    %% ─────────────────────────────────────────────
    %% AUTH GUARD
    %% ─────────────────────────────────────────────
    UNAUTH(["未認証アクセス\n→ Sign in required 画面"]):::external
    OPS_CHATS -->|"未ログイン時"| UNAUTH
    ADMIN_DASH -->|"未ログイン / 非admin時"| UNAUTH
    UNAUTH -->|"Sign In ボタン"| PORTAL

    %% ─────────────────────────────────────────────
    %% LOGOUT
    %% ─────────────────────────────────────────────
    LOGOUT(["ログアウト\n（サイドバーフッター）"]):::external
    OPS_DETAIL -->|"ログアウト"| LOGOUT
    OPS_CHATS -->|"ログアウト"| LOGOUT
    ADMIN_DASH -->|"ログアウト"| LOGOUT
    LOGOUT -->|"セッションクリア\n→ /portal"| PORTAL

    %% ─────────────────────────────────────────────
    %% EMAIL NOTIFICATIONS (side effects)
    %% ─────────────────────────────────────────────
    EMAIL_ADMIN(["📧 管理者へメール通知\n新規チャット開始時\nエスカレーション時"]):::side
    EMAIL_OPS(["📧 担当オペレーターへメール通知\nアサイン時"]):::side

    CHAT_ROOM -.->|"startSession\nまたは requestEscalation"| EMAIL_ADMIN
    W_CHAT -.->|"startSession\nまたは requestEscalation"| EMAIL_ADMIN
    ADMIN_REPLY -.->|"assignChat\n（operatorId指定時）"| EMAIL_OPS

    %% ─────────────────────────────────────────────
    %% STYLES
    %% ─────────────────────────────────────────────
    classDef entry fill:#000,color:#fff,stroke:#000,font-weight:bold
    classDef page fill:#fff,color:#111,stroke:#333,stroke-width:1.5px
    classDef modal fill:#f0f4ff,color:#111,stroke:#6366f1,stroke-width:1.5px
    classDef external fill:#f5f5f5,color:#555,stroke:#aaa,stroke-dasharray:4 2
    classDef side fill:#fff7ed,color:#92400e,stroke:#f59e0b,stroke-dasharray:4 2
